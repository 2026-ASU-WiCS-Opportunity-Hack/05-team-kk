---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  imageUrl?: string;
  chapterName: string;
}

const { title, subtitle, description, ctaText, ctaLink, imageUrl, chapterName } = Astro.props;

// Split title into words for staggered animation
const titleWords = title.split(" ");
---

<section class="relative overflow-hidden" aria-label="Hero">
  {/* Warm tinted background with organic shape */}
  <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--color-brand-primary-light) 0%, var(--color-warm-ivory) 50%, var(--color-brand-accent-light) 100%)"></div>

  {/* Decorative organic blob - CSS only */}
  <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full opacity-[0.04]" style="background: var(--color-brand-primary); filter: blur(60px)"></div>
  <div class="absolute -bottom-24 -left-24 w-72 h-72 rounded-full opacity-[0.03]" style="background: var(--color-brand-accent); filter: blur(50px)"></div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6">
    <div class={`py-16 md:py-24 flex flex-col justify-center ${imageUrl ? "md:grid md:grid-cols-[1fr_0.85fr] md:gap-12 lg:gap-20 md:items-center" : ""}`}>

      {/* Text content — editorial typography */}
      <div class={`${imageUrl ? "" : "max-w-3xl mx-auto text-center"}`}>
        {/* Overline */}
        <p class="overline text-brand-primary mb-4 hero-reveal" style="animation-delay:0ms">
          {chapterName}
        </p>

        {/* Title — large editorial display */}
        <h1 class="text-[2.5rem] sm:text-5xl md:text-[3.5rem] lg:text-[4rem] font-bold font-heading leading-[1.05] tracking-tight mb-6">
          {titleWords.map((word, i) => (
            <span class="inline-block hero-reveal" style={`animation-delay:${80 + i * 60}ms`}>
              {i === 0 ? (
                <span style="color:var(--color-brand-primary)">{word}&nbsp;</span>
              ) : (
                <span class="text-warm-charcoal">{word}&nbsp;</span>
              )}
            </span>
          ))}
        </h1>

        {subtitle && (
          <p class="text-lg md:text-xl font-heading font-medium text-text-secondary mb-4 hero-reveal" style="animation-delay:300ms">
            {subtitle}
          </p>
        )}

        {description && (
          <p class={`text-base md:text-lg text-text-secondary leading-relaxed mb-8 hero-reveal ${imageUrl ? "max-w-lg" : "max-w-2xl mx-auto"}`} style="animation-delay:380ms">
            {description}
          </p>
        )}

        {/* CTA + trust line */}
        <div class={`flex flex-col sm:flex-row items-start gap-4 hero-reveal ${imageUrl ? "" : "sm:items-center sm:justify-center"}`} style="animation-delay:460ms">
          {ctaText && ctaLink && (
            <a
              href={ctaLink}
              class="inline-flex items-center gap-2 px-7 py-3.5 text-base font-semibold rounded-full transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5"
              style="background:var(--color-brand-accent);color:var(--color-warm-charcoal)"
            >
              {ctaText}
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          )}
          <span class="text-xs text-text-muted flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            WIAL Global Network
          </span>
        </div>
      </div>

      {/* Hero image — editorial treatment with accent frame */}
      {imageUrl && (
        <div class="mt-10 md:mt-0 hero-reveal" style="animation-delay:300ms">
          <div class="relative">
            {/* Accent frame behind image */}
            <div class="absolute -inset-3 rounded-2xl opacity-20" style="background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-accent))"></div>
            <div class="absolute inset-0 rounded-2xl border-2 translate-x-3 translate-y-3 opacity-20" style="border-color: var(--color-brand-accent)"></div>
            <img
              src={imageUrl}
              alt={`${chapterName} Action Learning`}
              class="relative w-full rounded-2xl object-cover aspect-[4/3] shadow-lg"
              loading="eager"
              width="600"
              height="450"
            />
          </div>
        </div>
      )}
    </div>
  </div>

  {/* Bottom wave divider */}
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 56" preserveAspectRatio="none" class="w-full h-10 md:h-14" fill="var(--color-warm-ivory)">
      <path d="M0,32 C360,56 1080,0 1440,28 L1440,56 L0,56 Z"/>
    </svg>
  </div>
</section>

<style>
  .hero-reveal {
    opacity: 0;
    animation: heroFadeUp 0.7s cubic-bezier(0.2, 0, 0, 1) forwards;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
