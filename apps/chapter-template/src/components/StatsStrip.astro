---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

{stats.length > 0 && (
  <section class="bg-surface-muted border-y border-border-subtle" aria-label="Statistics">
    <div class="mx-auto max-w-[1200px] px-4 sm:px-6 py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="text-3xl md:text-4xl font-bold font-heading text-brand-primary">
              {stat.value}
            </p>
            <p class="text-sm text-text-secondary mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
