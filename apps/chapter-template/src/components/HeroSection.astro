---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  imageUrl?: string;
  chapterName: string;
}

const { title, subtitle, description, ctaText, ctaLink, imageUrl, chapterName } = Astro.props;
---

<section class="relative bg-brand-primary-light" aria-label="Hero">
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 py-16 md:py-24">
    <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-16">
      {/* Text content */}
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl font-bold font-heading tracking-tight mb-4" style="color:var(--color-brand-primary)">
          {title}
        </h1>
        {subtitle && (
          <p class="text-xl md:text-2xl font-heading font-medium text-text-secondary mb-4">
            {subtitle}
          </p>
        )}
        {description && (
          <p class="text-lg text-text-secondary leading-relaxed mb-8 max-w-lg mx-auto md:mx-0">
            {description}
          </p>
        )}
        {ctaText && ctaLink && (
          <a
            href={ctaLink}
            class="inline-block px-8 py-3.5 text-base font-semibold rounded-full bg-brand-accent text-warm-charcoal hover:opacity-90 transition-opacity shadow-md"
          >
            {ctaText}
          </a>
        )}
        <p class="mt-6 text-xs text-text-muted flex items-center justify-center md:justify-start gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          Part of the WIAL Global Network &mdash; 20+ chapters worldwide
        </p>
      </div>

      {/* Image */}
      {imageUrl && (
        <div class="flex-1 max-w-md md:max-w-none">
          <img
            src={imageUrl}
            alt={`${chapterName} Action Learning`}
            class="w-full rounded-2xl shadow-lg object-cover aspect-[4/3]"
            loading="eager"
            width="600"
            height="450"
          />
        </div>
      )}
    </div>
  </div>
</section>
